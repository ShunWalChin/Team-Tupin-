SITE_BIND=127.0.0.1
SITE_PUBLIC_PORT=48080
WGER_BIND=127.0.0.1
WGER_PUBLIC_PORT=48002

DJANGO_DEBUG=False
SECRET_KEY=replace-with-generated-secret
SIGNING_KEY=replace-with-generated-signing-key
SITE_URL=https://app.teamtupina.com.br
ALLOWED_HOSTS=app.teamtupina.com.br,teamtupina.com.br,www.teamtupina.com.br,127.0.0.1,localhost,team-tupina-v2-wger-web
CSRF_TRUSTED_ORIGINS=https://app.teamtupina.com.br,https://teamtupina.com.br,https://www.teamtupina.com.br,http://127.0.0.1:48002,http://localhost:48002
CORS_ALLOWED_ORIGINS=https://app.teamtupina.com.br,https://teamtupina.com.br,https://www.teamtupina.com.br,http://127.0.0.1:48080,http://127.0.0.1:48002,http://localhost:48080,http://localhost:48002
TIME_ZONE=America/Sao_Paulo

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

FROM_EMAIL=Team Tupina <no-reply@teamtupina.local>
ENABLE_EMAIL=False

DJANGO_DB_ENGINE=django_prometheus.db.backends.postgresql
DJANGO_DB_DATABASE=wger_team_tupina_v2
DJANGO_DB_USER=wger_team_tupina_v2
DJANGO_DB_PASSWORD=replace-with-generated-database-password
DJANGO_DB_HOST=postgres
DJANGO_DB_PORT=5432

DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://redis:6379/1
DJANGO_CACHE_TIMEOUT=300
DJANGO_CACHE_CLIENT_CLASS=django_redis.client.DefaultClient

CELERY_BROKER=redis://redis:6379/2
CELERY_BACKEND=redis://redis:6379/3
USE_CELERY=True

WGER_USE_GUNICORN=True
WGER_PORT=8000
DJANGO_PERFORM_MIGRATIONS=True
DJANGO_COLLECTSTATIC_ON_STARTUP=True
DJANGO_CLEAR_STATIC_FIRST=True

ALLOW_GUEST_USERS=False
ALLOW_REGISTRATION=False
ALLOW_UPLOAD_VIDEOS=True
DOWNLOAD_INGREDIENTS_FROM=WGER
SYNC_EXERCISES_CELERY=False
SYNC_EXERCISE_IMAGES_CELERY=False
SYNC_EXERCISE_VIDEOS_CELERY=False
SYNC_INGREDIENTS_CELERY=False

TEAM_TUPINA_SITE_URL=https://teamtupina.com.br
TEAM_TUPINA_PREMIUM_URL=https://teamtupina.com.br/premium.html
